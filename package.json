{
  "name": "oolong",
  "version": "0.6.0",
  "description": "A macOS desktop client for translation and native English optimization.",
  "packageManager": "pnpm@11.7.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -b && vite build",
    "clean:release": "node scripts/clean-release.mjs",
    "package": "pnpm clean:release && pnpm build && electron-builder",
    "lint": "tsc -b --noEmit",
    "test": "node --test tests/*.test.cjs"
  },
  "keywords": [
    "translation",
    "electron",
    "macos"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "dev.oolong.app",
    "productName": "oolong",
    "directories": {
      "output": "release"
    },
    "icon": "assets/icon.png",
    "protocols": [
      {
        "name": "oolong",
        "schemes": [
          "oolong"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/settings-defaults.json",
      "assets/icon.png",
      "assets/icon.icns",
      "assets/status-bar-icon.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
